<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    
    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>
        </Console>
        
        <!-- File Appender for Application Logs -->
        <File name="ApplicationFile" fileName="logs/application.log">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>
        </File>
        
        <!-- Rolling File Appender for Test Logs -->
        <RollingFile name="TestFile" fileName="logs/test-execution.log" 
                     filePattern="logs/test-execution-%i.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="5"/>
        </RollingFile>
        
        <!-- File Appender for Screenshot Operations -->
        <File name="ScreenshotFile" fileName="logs/screenshots.log">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>
        </File>
        
        <!-- File Appender for WebDriver Operations -->
        <File name="WebDriverFile" fileName="logs/webdriver.log">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>
        </File>
    </Appenders>
    
    <Loggers>
        <!-- Screenshot Utils Logger -->
        <Logger name="com.screenshot.app.utils.ScreenshotUtils" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ScreenshotFile"/>
        </Logger>
        
        <!-- Driver Manager Logger -->
        <Logger name="com.screenshot.app.utils.DriverManager" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="WebDriverFile"/>
        </Logger>
        
        <!-- Base Test Logger -->
        <Logger name="com.screenshot.app.base.BaseTest" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="TestFile"/>
        </Logger>
        
        <!-- Test Classes Logger -->
        <Logger name="com.screenshot.app.tests" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="TestFile"/>
        </Logger>
        
        <!-- Page Objects Logger -->
        <Logger name="com.screenshot.app.pages" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ApplicationFile"/>
        </Logger>
        
        <!-- Main Application Logger -->
        <Logger name="com.screenshot.app.ScreenshotApp" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ApplicationFile"/>
        </Logger>
        
        <!-- Selenium WebDriver Logs (suppress verbose logging) -->
        <Logger name="org.openqa.selenium" level="WARN" additivity="false">
            <AppenderRef ref="WebDriverFile"/>
        </Logger>
        
        <!-- TestNG Logs -->
        <Logger name="org.testng" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="TestFile"/>
        </Logger>
        
        <!-- Root Logger -->
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ApplicationFile"/>
        </Root>
    </Loggers>
    
</Configuration>